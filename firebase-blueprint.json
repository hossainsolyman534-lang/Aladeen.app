{
  "entities": {
    "AppData": {
      "title": "Application Data",
      "description": "Represents an Android application in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the app." },
        "developer": { "type": "string", "description": "The developer of the app." },
        "rating": { "type": "number", "description": "The average rating of the app." },
        "reviews": { "type": "string", "description": "The number of reviews (e.g., '1.2M')." },
        "size": { "type": "string", "description": "The size of the app (e.g., '35 MB')." },
        "downloads": { "type": "string", "description": "The number of downloads (e.g., '50M+')." },
        "category": { "type": "string", "description": "The category of the app." },
        "icon": { "type": "string", "description": "The URL of the app icon." },
        "banner": { "type": "string", "description": "The URL of the app banner." },
        "shortDescription": { "type": "string", "description": "A short description of the app." },
        "description": { "type": "string", "description": "The full description of the app." },
        "screenshots": { "type": "array", "items": { "type": "string" }, "description": "A list of screenshot URLs." },
        "promoVideo": { "type": "string", "description": "The URL of the promo video." },
        "isVerified": { "type": "boolean", "description": "Whether the app is verified." },
        "isTrending": { "type": "boolean", "description": "Whether the app is trending." },
        "isFeatured": { "type": "boolean", "description": "Whether the app is featured." },
        "addedAt": { "type": "string", "format": "date-time", "description": "The date the app was added." },
        "apkUrl": { "type": "string", "description": "The URL of the APK file." },
        "expiryDate": { "type": "string", "format": "date-time", "description": "The date the app expires." }
      },
      "required": ["name", "developer", "category", "icon", "banner", "shortDescription", "description", "screenshots", "addedAt"]
    },
    "ClientData": {
      "title": "Client Data",
      "description": "Represents a client partner.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the client." },
        "onBoardDate": { "type": "string", "format": "date", "description": "The date the client was onboarded." },
        "website": { "type": "string", "description": "The client's website URL." },
        "facebook": { "type": "string", "description": "The client's Facebook page URL." },
        "contactNumber": { "type": "string", "description": "The client's contact number." },
        "notes": { "type": "string", "description": "Additional notes about the client." }
      },
      "required": ["name", "onBoardDate", "contactNumber"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile and activities.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role." },
        "photoURL": { "type": "string", "description": "The user's photo URL." },
        "installedApps": { "type": "array", "items": { "type": "string" }, "description": "A list of installed app IDs." },
        "wishlist": { "type": "array", "items": { "type": "string" }, "description": "A list of wishlisted app IDs." },
        "reviews": { "type": "object", "description": "A map of app IDs to user reviews." }
      },
      "required": ["name", "email", "role"]
    }
  },
  "firestore": {
    "/apps/{appId}": {
      "schema": "AppData",
      "description": "Collection of applications."
    },
    "/clients/{clientId}": {
      "schema": "ClientData",
      "description": "Collection of client partners."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
